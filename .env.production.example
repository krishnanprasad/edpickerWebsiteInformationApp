PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE  # e.g., Supabase connection string

# Redis (BullMQ + cache) - Upstash
IS_LOCAL=0
UPSTASH_TOKEN=YOUR_UPSTASH_TOKEN_HERE
REDIS_URL_LOCAL=redis://localhost:6379
REDIS_URL_CLOUD=rediss://default:${UPSTASH_TOKEN}@evolved-primate-58101.upstash.io:6379
REDIS_URL=rediss://default:${UPSTASH_TOKEN}@evolved-primate-58101.upstash.io:6379
REDIS_HOST=evolved-primate-58101.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=${UPSTASH_TOKEN}
CLASSIFY_QUEUE_NAME=schoollens-classify
CRAWLER_QUEUE_NAME=schoollens-crawl
SCORING_QUEUE_NAME=schoollens-score
EDUCATION_CONFIDENCE_THRESHOLD=40

# Internal API security
INTERNAL_API_KEY=change-me

# Worker callback (public API base)
CRAWLER_API_BASE_URL=https://api.your-domain.com
CRAWLER_MAX_PAGES=30

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL_CHAT=gpt-4o
OPENAI_MODEL_SCORING=gpt-4o-mini

# File storage (cloud bucket)
STORAGE_PROVIDER=s3
STORAGE_BUCKET=schoollens-assets
S3_ENDPOINT=https://storage.googleapis.com
S3_REGION=auto
S3_ACCESS_KEY=YOUR_ACCESS_KEY
S3_SECRET_KEY=YOUR_SECRET_KEY
AZURE_STORAGE_CONNECTION_STRING=

# B2B CTA
B2B_CTA_URL=https://edpicker.com/verify
