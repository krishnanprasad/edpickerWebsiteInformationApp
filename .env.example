PORT=3000
DATABASE_URL=postgresql://dev:dev@localhost:5432/edpicker-crawler-app

# Redis (BullMQ + cache)
IS_LOCAL=1
REDIS_URL_LOCAL=redis://localhost:6379
REDIS_URL_CLOUD=
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CLASSIFY_QUEUE_NAME=schoollens-classify
CRAWLER_QUEUE_NAME=schoollens-crawl
SCORING_QUEUE_NAME=schoollens-score
EDUCATION_CONFIDENCE_THRESHOLD=40

# Internal API security
INTERNAL_API_KEY=change-me

# Worker callback
CRAWLER_API_BASE_URL=http://localhost:3000
CRAWLER_MAX_PAGES=30

# OpenAI (implement now, key can be set later)
OPENAI_API_KEY=sk-...
OPENAI_MODEL_CHAT=gpt-4o
OPENAI_MODEL_SCORING=gpt-4o-mini

# Gemini (Level-2 audit + OpenAI failover; cheap default model)
GEMINI_API_KEY=
GEMINI_MODEL_SCORING=gemini-1.5-flash-8b
GEMINI_MODEL_AUDIT=gemini-1.5-flash-8b

# File storage
STORAGE_PROVIDER=s3
STORAGE_BUCKET=schoollens-assets
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
