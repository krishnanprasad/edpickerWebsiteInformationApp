{
  "hosting": {
    "public": "dist/web/browser/browser",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "schoollens-api",
          "region": "asia-south2"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
